{
  "name": "bunce-node",
  "version": "0.0.1",
  "description": "Node SDK for Bunce APIs",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "packageManager": "pnpm@11.10.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "engineStrict": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trybunce/bunce-node.git"
  },
  "keywords": [
    "Bunce",
    "API",
    "Node",
    "SDK",
    "Customer Engagement"
  ],
  "author": "Damilare Anjorin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/trybunce/bunce-node/issues"
  },
  "homepage": "https://github.com/trybunce/bunce-node#readme",
  "scripts": {
    "build": "tsdown",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "rimraf 'dist' 'coverage'",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false",
    "release": "bumpp package.json --commit --push --tag",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "axios": "^1.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "bumpp": "^11.0.0",
    "lint-staged": "^16.0.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "rimraf": "^6.0.0",
    "simple-git-hooks": "^2.9.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "type": "module"
}
